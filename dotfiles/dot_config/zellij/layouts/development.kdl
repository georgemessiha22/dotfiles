layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }
    tab name="Neovim " {
        pane command="nvim"
    }
    tab name="Reward " cwd="./HungerStation/reward" {

    }
    tab name="Offer " cwd="./HungerStation/offer" {

    }
}

