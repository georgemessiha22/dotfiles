pane_frames true
layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        }
        children
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }
    tab name="Neovim " {
        pane command="nvim"
    }
    tab name="Shell " split_direction="vertical" {
        pane
        pane size="30%"
    }
    tab name="Lazygit " {
        pane {
            command "lazygit"
        }
    }
}

